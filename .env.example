# =====================================================================
#  CLOUDFLARE SINGLE EMAIL VIEWER  —  KONFIGURASI (.env)
# ---------------------------------------------------------------------
#  Salin file ini menjadi ".env" lalu edit lewat VPS:  nano .env
#  Jangan pernah commit file .env yang sudah berisi token asli.
# =====================================================================

# --- PENGATURAN TAMPILAN WEB (boleh dilihat publik) ------------------
# Nama besar yang tampil di tengah landing page.
NEXT_PUBLIC_SITE_NAME="NamaWebKeren"
# Warna aksen utama UI (hex). Mengubah glow, tombol, dan animasi 3D.
NEXT_PUBLIC_THEME_COLOR="#8b5cf6"

# --- KREDENSIAL CLOUDFLARE (SANGAT RAHASIA) --------------------------
# API Token Cloudflare. Untuk membaca email yang disimpan di KV cukup
# izin:  Account > Workers KV Storage > Read.
CLOUDFLARE_API_TOKEN="masukkan_api_token_cloudflare_anda_yang_panjang_disini"

# Account ID Cloudflare Anda (Dashboard > kanan bawah / URL).
CLOUDFLARE_ACCOUNT_ID="masukkan_account_id_anda_disini"

# ID KV Namespace tempat Email Worker menyimpan pesan masuk.
# (lihat README bagian "Setup Email Worker + KV").
CLOUDFLARE_KV_NAMESPACE_ID="masukkan_kv_namespace_id_disini"

# --- OPSIONAL --------------------------------------------------------
# Port HTTP server (default 3000).
PORT=3000

# Batasi domain/email yang boleh dicek (pisahkan dengan koma).
# Kosongkan untuk mengizinkan semua. Contoh: "domainanda.com,kantor.id"
ALLOWED_DOMAINS=""

# Mode demo: tampilkan email contoh tanpa memanggil Cloudflare.
# Otomatis aktif bila kredensial Cloudflare di atas belum diisi.
# Set "true" untuk memaksa demo, "false" untuk mematikan.
DEMO_MODE=""
